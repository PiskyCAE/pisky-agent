# pisky-agent environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control — it's in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Solana wallet private key (base58 encoded)
# Generate one with: node agent.js init
# This wallet needs SOL (for trades + fees) and PISKY (for API calls)
AGENT_KEYPAIR=your_base58_private_key_here

# Helius RPC URL — get a free key at https://helius.dev
# Required for wallet balance reads and swap transaction submission.
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# ── LLM ───────────────────────────────────────────────────────────────────────

# OpenRouter API key — get one at https://openrouter.ai/keys
# Required if using OpenRouter models (default). Not needed for Ollama.
OPENROUTER_API_KEY=sk-or-v1-...

# ── Telegram (optional but recommended) ───────────────────────────────────────

# Telegram bot token — create a bot via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# ── Swap execution (optional) ─────────────────────────────────────────────────

# Jupiter API key for higher swap rate limits — get at https://jup.ag
# Without this you use the shared public rate limit (usually fine for 1 agent)
JUPITER_API_KEY=

# ── Self-hosting override (advanced) ──────────────────────────────────────────

# Only set these if you run pisky-data-api on the same server as this agent.
# PISKY_API_URL overrides config/agent.json at runtime — no git changes needed.
# PISKY_INTERNAL_KEY bypasses x402 PISKY payment (localhost deployments only).
# Leave blank if using the public API at https://api.pisky.xyz
PISKY_API_URL=
PISKY_INTERNAL_KEY=
